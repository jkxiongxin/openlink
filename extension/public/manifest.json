{
  "manifest_version": 3,
  "name": "OpenLink",
  "version": "1.0.0",
  "description": "OpenLink 代理 - 连接 AI 与本地环境",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": [
    "http://127.0.0.1:*/*",
    "https://chatgpt.com/*",
    "https://*.chatgpt.com/*",
    "https://claude.ai/*",
    "https://www.kimi.com/*",
    "https://*.kimi.com/*",
    "https://*.moonshot.cn/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://chat.z.ai/*",
    "https://labs.google/*",
    "https://cdn.qwenlm.ai/*",
    "https://*.qwenlm.ai/*",
    "https://qwen-webui-prod.oss-accelerate.aliyuncs.com/*",
    "https://storage.googleapis.com/*",
    "https://aisandbox-pa.googleapis.com/*",
    "https://lh3.googleusercontent.com/*",
    "https://*.googleusercontent.com/*",
    "https://*.usercontent.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://chatgpt.com/*", "*://*.chatgpt.com/*", "*://claude.ai/*", "*://www.kimi.com/*", "*://*.kimi.com/*", "*://*.moonshot.cn/*", "*://www.perplexity.ai/*", "*://perplexity.ai/*", "*://chat.z.ai/*", "*://*.gemini.google.com/*", "*://aistudio.google.com/*", "*://arena.ai/*", "*://chat.deepseek.com/*", "*://tongyi.aliyun.com/*", "*://chat.qwen.ai/*", "*://www.doubao.com/*", "*://doubao.com/*", "*://labs.google/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["*://chatgpt.com/*", "*://*.chatgpt.com/*", "*://claude.ai/*", "*://www.kimi.com/*", "*://*.kimi.com/*", "*://*.moonshot.cn/*", "*://www.perplexity.ai/*", "*://perplexity.ai/*", "*://chat.z.ai/*", "*://*.gemini.google.com/*", "*://aistudio.google.com/*", "*://arena.ai/*", "*://chat.deepseek.com/*", "*://tongyi.aliyun.com/*", "*://chat.qwen.ai/*", "*://www.doubao.com/*", "*://doubao.com/*", "*://labs.google/*"]
    }
  ]
}
